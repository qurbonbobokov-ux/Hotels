@page "/hotels"
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Hotels — Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Hotels</h1>
    <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ Add Hotel</button>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-info py-2">@_message</div>
}

@if (_editing is not null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title">@(_editId is null ? "Add Hotel" : "Edit Hotel")</h5>
            <EditForm Model="_editing" OnValidSubmit="Save">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_editing.Name" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">City</label>
                        <InputText class="form-control" @bind-Value="_editing.City" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Address</label>
                        <InputText class="form-control" @bind-Value="_editing.Address" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Price / night</label>
                        <InputNumber class="form-control" @bind-Value="_editing.Price" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone</label>
                        <InputText class="form-control" @bind-Value="_editing.Phone" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="_editing.Email" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <InputTextArea class="form-control" rows="2" @bind-Value="_editing.Description" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Image URL</label>
                        <InputText class="form-control" @bind-Value="_editing.ImageUrl" placeholder="https://example.com/photo.jpg" />
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_editing.ImageUrl))
                    {
                        <div class="col-12">
                            <label class="form-label">Preview</label>
                            <div class="border rounded p-2">
                                <img src="@_editing.ImageUrl" alt="Hotel image preview" class="img-fluid" />
                            </div>
                        </div>
                    }
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-primary" type="submit" disabled="@_busy">Save</button>
                    <button class="btn btn-outline-secondary" type="button" @onclick="Cancel">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (_hotels is null)
{
    <p>Loading...</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle bg-white shadow-sm">
            <thead class="table-light">
                <tr>
                    <th>Name</th><th>City</th><th>Address</th><th>Image</th><th>Rating</th><th>Price</th><th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in _hotels)
                {
                    <tr>
                        <td>@h.Name</td>
                        <td>@h.City</td>
                        <td>@h.Address</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(h.ImageUrl))
                            {
                                <img src="@h.ImageUrl" alt="@h.Name" class="img-thumbnail" style="max-width: 80px; max-height: 60px;" />
                            }
                        </td>
                        <td>⭐ @h.Rating</td>
                        <td>$@h.Price</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenForm(h)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(h)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<HotelModel>? _hotels;
    private SaveHotelRequest? _editing;
    private Guid? _editId;
    private bool _busy;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        await Api.InitializeAsync();
        if (!Api.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load() => _hotels = await Api.GetHotelsAsync();

    private void OpenForm(HotelModel? h)
    {
        _message = null;
        if (h is null)
        {
            _editId = null;
            _editing = new SaveHotelRequest();
        }
        else
        {
            _editId = h.Id;
            _editing = new SaveHotelRequest
            {
                Name = h.Name, City = h.City, Address = h.Address,
                Price = h.Price, Description = h.Description
            };
        }
    }

    private void Cancel() => _editing = null;

    private async Task Save()
    {
        _busy = true;
        var resp = _editId is null
            ? await Api.CreateHotelAsync(_editing!)
            : await Api.UpdateHotelAsync(_editId.Value, _editing!);
        _busy = false;

        if (resp.IsSuccessStatusCode)
        {
            _editing = null;
            _message = _editId is null ? "Hotel created." : "Hotel updated.";
            await Load();
        }
        else
        {
            _message = $"Save failed ({(int)resp.StatusCode}).";
        }
    }

    private async Task Delete(HotelModel h)
    {
        var resp = await Api.DeleteHotelAsync(h.Id);
        _message = resp.IsSuccessStatusCode ? "Hotel deleted." : $"Delete failed ({(int)resp.StatusCode}).";
        await Load();
    }
}
